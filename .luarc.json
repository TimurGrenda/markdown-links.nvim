{
  "runtime": {
    "version": "LuaJIT",
    "path": ["lua/?.lua", "lua/?/init.lua"]
  },
  "workspace": {
    "library": [
      "${3rd}/busted/library",
      "${3rd}/luassert/library",
      "/usr/share/nvim/runtime/lua",
            "${3rd}/luv/library"
    ],
    "checkThirdParty": "Apply"
  },
  "diagnostics": {
    "globals": [
      "describe",
      "it",
      "before_each",
      "after_each",
      "setup",
      "teardown",
      "pending",
      "spy",
      "stub",
      "mock"
    ],
    "disable": ["luadoc-miss-module-name", "duplicate-set-field"]
  }
}
